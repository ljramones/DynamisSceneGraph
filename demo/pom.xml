<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
             http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>org.dynamisengine.scenegraph.demo</groupId>
  <artifactId>dynamisscenegraph-demo</artifactId>
  <version>1.0.0-SNAPSHOT</version>
  <packaging>pom</packaging>

  <name>DynamisSceneGraph Demos</name>
  <description>Standalone demos for DynamisSceneGraph (not part of main reactor).</description>

  <modules>
    <module>demo-projection</module>
  </modules>

  <properties>
    <maven.compiler.release>25</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

    <junit.version>5.11.4</junit.version>

    <scenegraph.version>1.0.0-SNAPSHOT</scenegraph.version>
    <ecs.version>1.0.0-SNAPSHOT</ecs.version>
    <session.version>1.0.0-SNAPSHOT</session.version>
    <vectrix.version>1.10.13</vectrix.version>
  </properties>

  <dependencyManagement>
    <dependencies>
      <dependency>
        <groupId>org.dynamisengine.scenegraph</groupId>
        <artifactId>scene-api</artifactId>
        <version>${scenegraph.version}</version>
      </dependency>
      <dependency>
        <groupId>org.dynamisengine.scenegraph</groupId>
        <artifactId>scene-core</artifactId>
        <version>${scenegraph.version}</version>
      </dependency>

      <dependency>
        <groupId>org.dynamisengine.ecs</groupId>
        <artifactId>ecs-api</artifactId>
        <version>${ecs.version}</version>
      </dependency>
      <dependency>
        <groupId>org.dynamisengine.ecs</groupId>
        <artifactId>ecs-core</artifactId>
        <version>${ecs.version}</version>
      </dependency>

      <dependency>
        <groupId>org.dynamisengine.session</groupId>
        <artifactId>session-api</artifactId>
        <version>${session.version}</version>
      </dependency>
      <dependency>
        <groupId>org.dynamisengine.session</groupId>
        <artifactId>session-core</artifactId>
        <version>${session.version}</version>
      </dependency>
      <dependency>
        <groupId>org.dynamisengine.session</groupId>
        <artifactId>session-runtime</artifactId>
        <version>${session.version}</version>
      </dependency>

      <dependency>
        <groupId>org.vectrix</groupId>
        <artifactId>vectrix</artifactId>
        <version>${vectrix.version}</version>
      </dependency>

      <dependency>
        <groupId>org.junit.jupiter</groupId>
        <artifactId>junit-jupiter</artifactId>
        <version>${junit.version}</version>
        <scope>test</scope>
      </dependency>
    </dependencies>
  </dependencyManagement>

  <build>
    <pluginManagement>
      <plugins>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-compiler-plugin</artifactId>
          <version>3.14.0</version>
          <configuration>
            <release>25</release>
            <compilerArgs>
              <arg>--enable-preview</arg>
            </compilerArgs>
          </configuration>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-surefire-plugin</artifactId>
          <version>3.5.2</version>
          <configuration>
            <argLine>--enable-preview</argLine>
          </configuration>
        </plugin>
        <plugin>
          <groupId>org.codehaus.mojo</groupId>
          <artifactId>exec-maven-plugin</artifactId>
          <version>3.3.0</version>
        </plugin>
      </plugins>
    </pluginManagement>
  </build>
</project>
